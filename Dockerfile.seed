# Dockerfile to run seed script with compatible Node/OpenSSL
FROM node:22-alpine

WORKDIR /app

# Copy backend files
COPY backend/package.json backend/package-lock.json ./
COPY backend/.env ./.env 
COPY backend/models ./models
COPY backend/seed.js ./seed.js

# Install dependencies
RUN npm ci

# Run seed script
CMD ["node", "seed.js"]
