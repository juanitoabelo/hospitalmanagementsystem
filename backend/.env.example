# backend/.env.example
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# MongoDB connection string
# If you use Atlas, include the database name and retry options.
# Encode special characters in the username/password before pasting.
MONGO_URI=mongodb://localhost:27017/medicore

# Example Atlas URI:
# MONGO_URI=mongodb+srv://user:password@cluster0.abc123.mongodb.net/medicore?retryWrites=true&w=majority

# JWT secret — CHANGE THIS in production!
JWT_SECRET=medicore-super-secret-key-change-me

# Token expiry (e.g. 1h, 7d, 30m)
JWT_EXPIRES=1h

# Server port
PORT=5000

# Frontend URL for CORS (no trailing slash)
CLIENT_URL=http://localhost:3000

